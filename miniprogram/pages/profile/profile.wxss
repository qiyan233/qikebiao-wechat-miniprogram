/* pages/profile/profile.wxss */

page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.container {
  min-height: 100vh;
  background-color: #F5F5F7;
}

.user-header {
  background: white;
  padding: 96rpx 40rpx 48rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.03);
  margin-bottom: 32rpx;
  animation: fadeIn 0.3s ease forwards;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.user-info {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.avatar-button {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-button::after {
  border: none;
}

.avatar,
.avatar-image {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar {
  background: linear-gradient(135deg, #4FACFE 0%, #00F2FE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(79, 172, 254, 0.3);
}

.avatar-image {
  box-shadow: 0 8rpx 24rpx rgba(79, 172, 254, 0.22);
  background: #EAF4FF;
}

.user-detail {
  flex: 1;
  min-width: 0;
}

.nickname-input {
  height: 72rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: -0.02em;
  line-height: 72rpx;
}

.nickname-placeholder {
  color: #B5B5BC;
}

.user-role {
  font-size: 24rpx;
  color: #86868B;
  margin-top: 10rpx;
}

.stats-section {
  padding: 0 40rpx;
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #86868B;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.stats-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  display: flex;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-item:first-child {
  border-right: 1rpx solid rgba(0, 0, 0, 0.05);
}

.stat-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 8rpx;
}

.stat-value.highlight {
  color: #0071E3;
}

.stat-label {
  font-size: 22rpx;
  color: #86868B;
  font-weight: 500;
}

.settings-section {
  padding: 0 40rpx;
}

.settings-card {
  background: white;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.setting-item {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  transition: background 0.2s;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: rgba(0, 0, 0, 0.02);
}

.setting-item.danger:active {
  background: rgba(255, 59, 48, 0.05);
}

.setting-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.setting-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.setting-icon.purple {
  background: rgba(175, 82, 222, 0.1);
  color: #AF52DE;
}

.setting-icon.orange {
  background: rgba(255, 149, 0, 0.1);
  color: #FF9500;
}

.setting-icon.green {
  background: rgba(52, 199, 89, 0.1);
  color: #34C759;
}

.setting-icon.blue {
  background: rgba(0, 113, 227, 0.1);
  color: #0071E3;
}

.setting-icon.red {
  background: rgba(255, 59, 48, 0.1);
  color: #FF3B30;
}

.setting-text {
  flex: 1;
  font-size: 30rpx;
  color: #1D1D1F;
  font-weight: 500;
}

.setting-text.danger {
  color: #FF3B30;
}

.setting-arrow {
  color: #C7C7CC;
  font-size: 32rpx;
}

.setting-input {
  font-size: 28rpx;
  color: #86868B;
  background: rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  text-align: right;
}

.setting-input.compact {
  min-width: 160rpx;
  padding: 12rpx 20rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding-left: 88rpx;
  margin-top: 16rpx;
}

.align-start {
  align-items: flex-start;
}

.push-key-input {
  flex: 1;
  font-size: 28rpx;
  color: #1D1D1F;
  background: rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.template-json-textarea {
  width: 100%;
  min-height: 220rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #1D1D1F;
  background: rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.reminder-actions-row {
  padding-top: 8rpx;
}

.dual-actions-row {
  gap: 16rpx;
}

.test-reminder-btn {
  flex: 1;
  width: 100%;
  background: linear-gradient(135deg, #34C759 0%, #30B75A 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  border-radius: 18rpx;
  padding: 18rpx 24rpx;
  line-height: 1.2;
  box-shadow: 0 8rpx 20rpx rgba(52, 199, 89, 0.18);
}

.test-reminder-btn::after {
  border: none;
}

.test-reminder-btn:active {
  transform: scale(0.98);
  opacity: 0.92;
}

.blue-btn {
  background: linear-gradient(135deg, #0071E3 0%, #4F9DFF 100%);
  box-shadow: 0 8rpx 20rpx rgba(0, 113, 227, 0.18);
}

.secondary-btn {
  background: rgba(52, 199, 89, 0.12);
  color: #1F9D49;
  border: 1rpx solid rgba(52, 199, 89, 0.28);
  box-shadow: none;
}

.setting-tip-inline {
  padding-left: 88rpx;
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #86868B;
}

.scan-result-box {
  width: 100%;
  background: rgba(52, 199, 89, 0.08);
  border: 1rpx solid rgba(52, 199, 89, 0.18);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  color: #1D1D1F;
  font-size: 24rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.day-course-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.day-course-card {
  width: 100%;
  background: #F8FBF8;
  border: 1rpx solid rgba(52, 199, 89, 0.14);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.day-course-card.selected {
  background: rgba(52, 199, 89, 0.12);
  border-color: rgba(52, 199, 89, 0.34);
  box-shadow: 0 8rpx 18rpx rgba(52, 199, 89, 0.12);
}

.day-course-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.day-course-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.day-course-badge {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #1F9D49;
  background: rgba(52, 199, 89, 0.12);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.day-course-meta {
  font-size: 23rpx;
  line-height: 1.7;
  color: #5C5C63;
}

.setting-subtext {
  font-size: 26rpx;
  color: #86868B;
}

.setting-tip {
  font-size: 22rpx;
  color: #86868B;
  padding: 0 40rpx 32rpx;
}

.login-card {
  margin: 80rpx 40rpx;
  background: white;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  text-align: center;
}

.login-icon {
  width: 128rpx;
  height: 128rpx;
  background: linear-gradient(135deg, #4FACFE 0%, #00F2FE 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  font-size: 64rpx;
  box-shadow: 0 8rpx 32rpx rgba(79, 172, 254, 0.3);
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #86868B;
  margin-bottom: 48rpx;
}

.login-btn {
  background: #0071E3;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  padding: 28rpx 80rpx;
  border-radius: 980rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 113, 227, 0.3);
}

.login-btn:active {
  transform: scale(0.98);
}
