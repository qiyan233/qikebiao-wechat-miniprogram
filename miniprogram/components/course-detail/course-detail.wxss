/* components/course-detail/course-detail.wxss */

/* 遮罩层 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  z-index: 40;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.mask.visible {
  opacity: 1;
  visibility: visible;
}

/* 底部抽屉 */
.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(36rpx) saturate(180%);
  -webkit-backdrop-filter: blur(36rpx) saturate(180%);
  border-radius: 36rpx 36rpx 0 0;
  padding: 24rpx 24rpx 0;
  z-index: 50;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -16rpx 56rpx rgba(0, 0, 0, 0.1);
  max-height: calc(78vh - 120rpx);
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.sheet.visible {
  transform: translateY(0);
}

.sheet-body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 0 4rpx 20rpx;
}

.sheet-footer {
  flex-shrink: 0;
  padding: 12rpx 4rpx calc(24rpx + env(safe-area-inset-bottom) + 112rpx);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0.98) 24%);
}


/* 拖拽指示器 */
.handle {
  width: 60rpx;
  height: 8rpx;
  background: rgba(0, 0, 0, 0.15);
  border-radius: 6rpx;
  margin: -8rpx auto 28rpx;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.header-info {
  flex: 1;
  padding-right: 20rpx;
}

.course-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 6rpx;
  line-height: 1.25;
  letter-spacing: -0.02em;
}

.course-teacher {
  font-size: 24rpx;
  color: #86868B;
  font-weight: 500;
}

.header-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.14);
}

.header-icon-text {
  font-size: 38rpx;
}


/* 渐变色系 */
.bg-apple-pink { background: linear-gradient(135deg, #FF6B8B 0%, #FF8E53 100%); }
.bg-apple-blue { background: linear-gradient(135deg, #4FACFE 0%, #00F2FE 100%); }
.bg-apple-green { background: linear-gradient(135deg, #43E97B 0%, #38F9D7 100%); }
.bg-apple-purple { background: linear-gradient(135deg, #B185DB 0%, #C892FF 100%); }
.bg-apple-orange { background: linear-gradient(135deg, #FA709A 0%, #FEE140 100%); }
.bg-apple-cyan { background: linear-gradient(135deg, #00C6FB 0%, #005BEA 100%); }
.bg-apple-yellow { background: linear-gradient(135deg, #F6D365 0%, #FDA085 100%); }

/* 信息卡片 */
.info-card {
  background: rgba(0, 0, 0, 0.03);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.info-icon.blue {
  background: rgba(0, 113, 227, 0.1);
  color: #0071E3;
}

.info-icon.orange {
  background: rgba(255, 149, 0, 0.1);
  color: #FF9500;
}

.info-icon.purple {
  background: rgba(175, 82, 222, 0.1);
  color: #AF52DE;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 22rpx;
  color: #86868B;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: #1D1D1F;
  font-weight: 600;
}

.info-sub {
  font-size: 22rpx;
  color: #C7C7CC;
  margin-top: 4rpx;
}

/* 关闭按钮 */
.close-btn {
  width: 100%;
  padding: 28rpx;
  background: rgba(0, 0, 0, 0.05);
  color: #1D1D1F;
  font-weight: 700;
  font-size: 32rpx;
  border-radius: 24rpx;
  border: none;
  transition: background 0.2s;
}

.close-btn:active {
  background: rgba(0, 0, 0, 0.1);
}
